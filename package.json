{
  "name": "documentation_robotics_viewer",
  "version": "0.2.3",
  "private": true,
  "description": "Basic graph presentation of the documentation robotics meta-model",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.embedded.ts --port 3001 --host",
    "dev:embedded": "vite --config vite.config.embedded.ts --port 3001 --host",
    "build": "npm run client:generate && npm run client:check-version && vite build --config vite.config.embedded.ts && npm run package:embedded",
    "package:embedded": "node scripts/package-embedded.cjs",
    "preview": "vite preview --config vite.config.embedded.ts",
    "start": "bash scripts/start-servers.sh",
    "verify": "bash scripts/verify-setup.sh",
    "sync:api-spec": "bash scripts/sync-api-spec.sh",
    "client:generate": "openapi-typescript docs/api-spec.yaml -o src/core/types/api-client.ts && node scripts/generate-api-client.js",
    "client:check-version": "node scripts/check-api-version.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-router": "^1.139.12",
    "@tinkermonkey/heimdall-ui": "github:tinkermonkey/heimdall#c759edfb199bc796ce387b9c1b598b60fbf89551",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.5.0",
    "tailwindcss": "^4.1.17",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": ".husky/pre-commit",
      "post-merge": ".husky/post-merge",
      "post-checkout": ".husky/post-checkout"
    }
  }
}
